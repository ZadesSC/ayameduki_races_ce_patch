			<li Class="PatchOperationFindMod">
				<mods>
					<li>[Aya]Nearmare Race</li>
				</mods>
				<match Class="PatchOperationSequence">
					<operations>
						<li Class="PatchOperationRemove">
							<xpath>Defs/HediffDef[defName="HAR_NM_Hediff_Potency_b"]/stages/li[minSeverity="0.2"]/statFactors/ArmorRating_Sharp</xpath>
						</li>
						<li Class="PatchOperationRemove">
							<xpath>Defs/HediffDef[defName="HAR_NM_Hediff_Potency_b"]/stages/li[minSeverity="0.2"]/statFactors/ArmorRating_Blunt</xpath>
						</li>
						<li Class="PatchOperationAdd">
							<xpath>Defs/HediffDef[defName="HAR_NM_Hediff_Potency_b"]/stages/li[minSeverity="0.2"]</xpath>
							<value>
								<statOffsets>
									<ArmorRating_Sharp>4</ArmorRating_Sharp>
									<ArmorRating_Blunt>10</ArmorRating_Blunt>
								</statOffsets>
							</value>
						</li>
					</operations>
				</match>
			</li>

