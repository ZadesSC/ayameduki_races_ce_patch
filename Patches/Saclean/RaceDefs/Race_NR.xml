<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>[Aya]Saclean Race</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[@Name="HAR_Saclean_BaseNRPawn"]/comps/li[@Class="CompProperties_Milkable"]/milkIntervalDays</xpath>
          <value>
            <milkIntervalDays>2</milkIntervalDays>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
