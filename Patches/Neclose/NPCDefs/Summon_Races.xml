<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationFindMod">
        <mods>
          <li>[Aya]Neclose Race</li>
        </mods>
        <match Class="PatchOperationSequence">
          <operations>

            <li Class="PatchOperationReplace">
              <xpath>Defs/ThingDef[@Name="HAR_NC_M_a_race_Base" or @Name="HAR_NC_M_b_race_Base" or @Name="HAR_NC_M_c_race_Base"]/statBases/ArmorRating_Sharp</xpath>
              <value>
                <ArmorRating_Sharp>0.01</ArmorRating_Sharp>
              </value>
            </li>

            <li Class="PatchOperationReplace">
              <xpath>Defs/ThingDef[@Name="HAR_NC_M_a_race_Base" or @Name="HAR_NC_M_b_race_Base" or @Name="HAR_NC_M_c_race_Base"]/statBases/ArmorRating_Blunt</xpath>
              <value>
                <ArmorRating_Blunt>0.01</ArmorRating_Blunt>
              </value>
            </li>

            <li Class="PatchOperationConditional">
              <xpath>Defs/ThingDef[@Name="HAR_NC_M_y_race_Base"]</xpath>
              <match Class="PatchOperationSequence">
                <operations>

                  <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[@Name="HAR_NC_M_y_race_Base" or @Name="HAR_NC_M_z_race_Base"]/statBases/ArmorRating_Sharp</xpath>
                    <value>
                      <ArmorRating_Sharp>0.01</ArmorRating_Sharp>
                    </value>
                  </li>

                  <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[@Name="HAR_NC_M_y_race_Base" or @Name="HAR_NC_M_z_race_Base"]/statBases/ArmorRating_Blunt</xpath>
                    <value>
                      <ArmorRating_Blunt>0.01</ArmorRating_Blunt>
                    </value>
                  </li>

                </operations>
              </match>
            </li>

          </operations>
        </match>
      </li>
    </operations>
  </Operation>
</Patch>
