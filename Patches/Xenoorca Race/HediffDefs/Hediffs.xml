			<li>[Aya]Xenoorca Race</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="HAR_XO_Hediff_b"]/stages/li/statOffsets/ArmorRating_Sharp</xpath>
