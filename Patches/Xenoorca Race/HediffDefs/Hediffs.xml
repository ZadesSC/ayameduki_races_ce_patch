				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="HAR_XO_Hediff_c"]/stages/li/statOffsets/ArmorRating_Sharp</xpath>
					<value>
						<ArmorRating_Sharp>3</ArmorRating_Sharp>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="HAR_XO_Hediff_c"]/stages/li/statOffsets/ArmorRating_Blunt</xpath>
					<value>
						<ArmorRating_Blunt>8</ArmorRating_Blunt>
