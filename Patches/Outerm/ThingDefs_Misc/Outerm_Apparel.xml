<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationSequence">
	<operations>
	  <li Class="PatchOperationFindMod">
			
		<mods><li>[Aya]Outerm Race</li></mods>
			
		<match Class="PatchOperationSequence">
		<operations>

			<!--========= Kakistos Lingerie =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
				defName="HAR_OT_Apparel_O_a" or
				defName="HAR_OT_Apparel_O_b" or
				defName="HAR_OT_Apparel_O_c"
				]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
					<Bulk>0.5</Bulk>
					<WornBulk>0.25</WornBulk>
				</value>
			</li>

			<!--========= Kakistos Headwear =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
				defName="HAR_OT_Apparel_H_a" or
				defName="HAR_OT_Apparel_H_b" or
				defName="HAR_OT_Apparel_H_c" or
				defName="HAR_OT_Apparel_H_d" or
				defName="HAR_OT_Apparel_H_e"
				]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>6</StuffEffectMultiplierArmor>
					<Bulk>1</Bulk>
					<WornBulk>1</WornBulk>
				</value>
			</li>

			<!--========= Kakistos Coats =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
				defName="HAR_OT_Apparel_S_a" or
				defName="HAR_OT_Apparel_S_b" or
				defName="HAR_OT_Apparel_S_c" or
				defName="HAR_OT_Apparel_S_d" or
				defName="HAR_OT_Apparel_S_e"
				]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
					<Bulk>10</Bulk>
					<WornBulk>5</WornBulk>
				</value>
			</li>

			<!--========= Kakistos Wear =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[
				defName="HAR_OT_Apparel_T_a" or
				defName="HAR_OT_Apparel_T_b" or
				defName="HAR_OT_Apparel_T_c" or
				defName="HAR_OT_Apparel_T_d" or
				defName="HAR_OT_Apparel_T_e" or
				defName="HAR_OT_Apparel_T_Suit_a"
				]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
					<Bulk>0.5</Bulk>
					<WornBulk>0.25</WornBulk>
				</value>
			</li>

			<!--========= Diaftra Armor =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_T_Armor_a"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<StuffEffectMultiplierArmor>0.1</StuffEffectMultiplierArmor>
					<ArmorRating_Sharp>18</ArmorRating_Sharp>
					<Bulk>80</Bulk>
					<WornBulk>10</WornBulk>
					<ArmorRating_Heat>2</ArmorRating_Heat>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_T_Armor_a"]/equippedStatOffsets</xpath>
				<value>
					<CarryWeight>70</CarryWeight>
					<CarryBulk>10</CarryBulk>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_T_Armor_a"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>42</ArmorRating_Blunt>
				</value>
			</li>

			<!--========= Diaftra Helmet =========-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_H_z"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<StuffEffectMultiplierArmor>0.1</StuffEffectMultiplierArmor>
					<ArmorRating_Sharp>16</ArmorRating_Sharp>
					<Bulk>40</Bulk>
					<WornBulk>10</WornBulk>
					<ArmorRating_Heat>2</ArmorRating_Heat>
					<NightVisionEfficiency_Apparel>0.6</NightVisionEfficiency_Apparel>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_H_z"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>40</ArmorRating_Blunt>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_H_z"]/apparel/bodyPartGroups</xpath>
				<value>
					<bodyPartGroups>
						<li>FullHead</li>
					</bodyPartGroups>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_OT_Apparel_H_z"]/apparel/layers</xpath>
				<value>
					<layers>
						<li>Overhead</li>
					</layers>
				</value>
			</li>

		</operations>
		</match>	
	  </li>
	</operations>	
  </Operation>
</Patch>
