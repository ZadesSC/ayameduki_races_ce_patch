<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationSequence">
	<operations>
	  <li Class="PatchOperationFindMod">
			
		<mods><li>[Aya]Solark Race</li></mods>
			
		<match Class="PatchOperationSequence">
		<operations>

        <!--========= Shemash Dress =========-->
        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Tops_d"]/statBases/ArmorRating_Sharp</xpath>
				<value>
				<ArmorRating_Sharp>15</ArmorRating_Sharp>
				<Bulk>40</Bulk>
				<WornBulk>10</WornBulk>
				</value>
		</li>

        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Tops_d"]/statBases/ArmorRating_Blunt</xpath>
				<value>
				<ArmorRating_Blunt>37.5</ArmorRating_Blunt>
				</value>
		</li>

        <!--========= Draconic Armor =========-->
        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Armor_a"]/statBases/ArmorRating_Sharp</xpath>
				<value>
				<StuffEffectMultiplierArmor>0.1</StuffEffectMultiplierArmor>
				<ArmorRating_Sharp>16</ArmorRating_Sharp>
				<Bulk>80</Bulk>
				<WornBulk>10</WornBulk>
				<ArmorRating_Heat>0.2</ArmorRating_Heat>
				</value>
		</li>

        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Armor_a"]/statBases/ArmorRating_Blunt</xpath>
				<value>
				<ArmorRating_Blunt>40</ArmorRating_Blunt>
				</value>
		</li>

		<!--========= Draconic Helmet =========-->
		<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="HAR_SA_Heads_d"]/statBases</xpath>
				<value>
				<StuffEffectMultiplierArmor>0.1</StuffEffectMultiplierArmor>
				<NightVisionEfficiency_Apparel>0.6</NightVisionEfficiency_Apparel>
				</value>
		</li>

        <!--========= Drake Barrier =========-->
        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Shell_c"]/statBases/ArmorRating_Sharp</xpath>
				<value>
				<StuffEffectMultiplierArmor>1</StuffEffectMultiplierArmor>
				<ArmorRating_Sharp>10</ArmorRating_Sharp>
				</value>
		</li>

        <li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="HAR_SA_Shell_c"]/statBases/ArmorRating_Blunt</xpath>
				<value>
				<ArmorRating_Blunt>10</ArmorRating_Blunt>
				</value>
		</li>

        </operations>
		</match>	
	  </li>
	</operations>	
  </Operation>
</Patch>
