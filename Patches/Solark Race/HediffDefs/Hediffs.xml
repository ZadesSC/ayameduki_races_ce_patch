<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>[Aya]Solark Race</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="Solark_Hediff_a"]/stages/li/statOffsets/ArmorRating_Sharp</xpath>
					<value>
						<ArmorRating_Sharp>24</ArmorRating_Sharp>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="Solark_Hediff_a"]/stages/li/statOffsets/ArmorRating_Blunt</xpath>
					<value>
						<ArmorRating_Blunt>55</ArmorRating_Blunt>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/HediffDef[defName="Solark_Hediff_a"]/stages/li/statOffsets/MeleeArmorPenetration</xpath>
					<value>
						<MeleeArmorPenetration>2.0</MeleeArmorPenetration>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>
